LOG_LEVEL=info
DEBUG=true
BOT_NAME=bot-test

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tiktok_crawler

# Organization IDs to crawl keywords from (comma-separated)
# Example: ORG_IDS=2,3,5
ORG_IDS=2

# GPM (GoLogin Profile Manager) - optional
# If both GPM_API and PROFILE_IDS are set, will use GPM instead of local Chrome
# Leave empty to use local Chrome
# Multiple profiles separated by comma: PROFILE_IDS=profile1,profile2,profile3
GPM_API=
PROFILE_IDS=

# API endpoint to push crawled data
API_URL=

# Cron schedule (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Output directory for crawled data
OUTPUT_DIR=./data

# Batch size per session
BATCH_MIN=5
BATCH_MAX=10

# Sleep between keywords (seconds) - default: 3-4 minutes
SLEEP_MIN_KEYWORD=180
SLEEP_MAX_KEYWORD=240

# Rest between sessions (seconds) - default: 5-10 minutes
REST_MIN_SESSION=300
REST_MAX_SESSION=600
