LOG_LEVEL=info
DEBUG=true
BOT_NAME=bot-test

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tiktok_crawler

# Organization ID to crawl keywords from
ORG_ID=2

# GPM (GoLogin Profile Manager) - optional
# If both GPM_API and PROFILE_ID are set, will use GPM instead of local Chrome
# Leave empty to use local Chrome
GPM_API=
PROFILE_ID=

# Cron schedule (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Output directory for crawled data
OUTPUT_DIR=./data

# Chrome path
CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# Batch size per session
BATCH_MIN=5
BATCH_MAX=10

# Sleep between keywords (seconds)
SLEEP_MIN_KEYWORD=60
SLEEP_MAX_KEYWORD=120

# Rest between sessions (seconds)
REST_MIN_SESSION=600
REST_MAX_SESSION=900
