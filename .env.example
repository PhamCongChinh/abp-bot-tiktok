LOG_LEVEL=info
DEBUG=false
BOT_NAME=abp-bot-tiktok

# GoLogin launcher sidecar (from instagram-crawler stack)
GOLOGIN_LAUNCHER_URL=http://gologin-launcher:4000

# Comma-separated GoLogin profile IDs to rotate through
TIKTOK_PROFILE_IDS=

# Postgres connection string
POSTGRES_DSN=postgres://user:password@postgres:5432/kolp?sslmode=disable

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=raw

# Crawler settings
SOURCE_ID=scraper_tiktok
CLAIM_CHUNK=5
CLAIM_POLL_INTERVAL_MS=10000
TIKTOK_CONTENT_PAGE_CAP=10
