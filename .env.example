LOG_LEVEL=info
DEBUG=false
BOT_NAME=bot-test

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tiktok_crawler

# Organization IDs to crawl keywords from (comma-separated)
# Example: ORG_IDS=2,3,5
ORG_IDS=2

# API endpoint to push crawled data
API_URL=

# GPM (GoLogin Profile Manager)
# Multiple profiles separated by comma: PROFILE_IDS=profile1,profile2,profile3
GPM_API=
PROFILE_IDS=
